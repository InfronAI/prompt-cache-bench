# API endpoints and credentials.
# Copy this file to `.env`, then fill in your own API keys before running live benchmarks.
INFRON_BASE_URL=https://api.infron.ai/v1
INFRON_API_KEY=

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=https://github.com/InfronAI/prompt-cache-bench
OPENROUTER_APP_TITLE=prompt-cache-bench

# Standard API client headers.
PROMPT_CACHE_BENCH_USER_AGENT=prompt-cache-bench/0.1.0
PROMPT_CACHE_BENCH_ACCEPT=application/json
PROMPT_CACHE_BENCH_CONNECTION=keep-alive

# Default benchmark design.
PROMPT_CACHE_BENCH_MODEL=deepseek/deepseek-v4-flash
PROMPT_CACHE_BENCH_DATASET_NAME=business_representative
PROMPT_CACHE_BENCH_ROUTING_SORTS=throughput,price,latency,ttft
PROMPT_CACHE_BENCH_GROUPS=4
PROMPT_CACHE_BENCH_ROUNDS=50
PROMPT_CACHE_BENCH_WORKERS=8
PROMPT_CACHE_BENCH_TIMEOUT_SECONDS=120
PROMPT_CACHE_BENCH_STREAM=true
PROMPT_CACHE_BENCH_INCLUDE_USAGE=true

# Public repository and release validation defaults.
PROMPT_CACHE_BENCH_REPO_URL=https://github.com/InfronAI/prompt-cache-bench
PROMPT_CACHE_BENCH_PAGES_BASE_URL=https://infronai.github.io/prompt-cache-bench
PROMPT_CACHE_BENCH_DEFAULT_EXPERIMENT=experiments/deepseek/deepseek-v4-flash/infron-vs-openrouter-routing-sort-cache-cost-4x50-stream-ttft-2026-06-27

# Optional: force both providers through the same local proxy for controlled network conditions.
AB_TEST_LOCAL_PROXY_URL=
